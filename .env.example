PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=prismrag
PGVECTOR_USER=prismrag
PGVECTOR_PASSWORD=prismrag
# FAISS 索引: <model>-<corpus>.faiss (版本化命名)
FAISS_INDEX_PATH=indexes/colpali-v1.3-vidore-industrial.faiss
FAISS_ID_MAP_PATH=indexes/colpali-v1.3-vidore-industrial-ids.npy
OLLAMA_BASE_URL=http://localhost:11434
# LLM block: the service consumes OPENAI_API_KEY (read by the Generator), not LLM_API_KEY.
# LLM_API_KEY is mapped to OPENAI_API_KEY by docker-compose.
OPENAI_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1   # optional override of llm.base_url
LLM_MODEL=gpt-4o-mini                    # optional override of llm.model

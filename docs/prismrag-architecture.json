{
  "schema_version": 1,
  "diagram_type": "architecture",
  "meta": {
    "title": "PrismRAG Architecture",
    "subtitle": "多模态 PDF RAG — 三路检索（BM25 · Dense · Visual）+ RRF 融合 + Cross-encoder 重排",

    { "id": "reranker", "type": "backend", "label": "Cross-encoder", "sublabel": "BGE / zerank-2", "pos": [1030, 300], "size": [180, 60] },
    { "id": "output", "type": "frontend", "label": "Top-k Results", "sublabel": "chunk_id + page_id", "pos": [1030, 390], "size": [180, 50] },

    { "id": "api", "type": "backend", "label": "FastAPI", "sublabel": "/search + /health", "pos": [1050, 510], "size": [110, 50] },

    { "id": "ablation", "type": "backend", "label": "Ablation Experiments", "sublabel": "10 configs · BM25/Dense/Visual toggles", "pos": [80, 650], "size": [290, 60] },

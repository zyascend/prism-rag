    { "id": "bge", "type": "backend", "label": "BGE Embedder", "sublabel": "1024-dim vectors", "pos": [60, 340], "size": [130, 60] },
    { "id": "colpali", "type": "backend", "label": "ColPali/ColQwen2", "sublabel": "Multi-vector encoding", "pos": [210, 340], "size": [140, 60] },

    { "id": "pgvector", "type": "database", "label": "pgvector", "sublabel": "chunks + BGE vectors", "pos": [460, 340], "size": [140, 65] },
    { "id": "faiss", "type": "database", "label": "FAISS", "sublabel": "page multi-vectors", "pos": [460, 430], "size": [140, 65] },

    { "id": "query", "type": "external", "label": "User Query", "sublabel": "natural language", "pos": [750, 100], "size": [130, 45] },
    { "id": "bm25", "type": "backend", "label": "BM25 (Lexical)", "sublabel": "keyword matching", "pos": [750, 210], "size": [130, 60] },
    { "id": "dense", "type": "backend", "label": "Dense (Semantic)", "sublabel": "BGE → pgvector HNSW", "pos": [750, 300], "size": [130, 60] },
    { "id": "visual", "type": "backend", "label": "Visual (Page Image)", "sublabel": "ColPali → FAISS", "pos": [750, 390], "size": [130, 60] },


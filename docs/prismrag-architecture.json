    { "id": "hyde", "type": "backend", "label": "HyDE + Reranker", "sublabel": "Qwen2:7b HyDE · zerank-2", "pos": [780, 650], "size": [290, 60] },
    { "id": "config", "type": "database", "label": "models.yaml", "sublabel": "model IDs · devices · paths", "pos": [1130, 650], "size": [250, 60] }
  ],
  "boundaries": [
    { "kind": "region", "label": "📥 Offline Ingestion", "wraps": ["dataset", "chunker", "bge", "colpali"], "pad": 20 },
    { "kind": "region", "label": "🗄️ Storage", "wraps": ["pgvector", "faiss"], "pad": 20 },
    { "kind": "region", "label": "🔍 Online Retrieval", "wraps": ["query", "bm25", "dense", "visual"], "pad": 20 },
    { "kind": "region", "label": "🧩 Fusion & Output", "wraps": ["fusion", "reranker", "output"], "pad": 20 },
    { "kind": "region", "label": "📊 Evaluation & Config", "wraps": ["ablation", "metrics", "hyde", "config"], "pad": 20 }
  ],
  "connections": [
    { "from": "dataset", "to": "chunker" },
    { "from": "chunker", "to": "bge" },
    { "from": "chunker", "to": "colpali" },
    { "from": "bge", "to": "pgvector", "variant": "dashed" },
    { "from": "colpali", "to": "faiss", "variant": "dashed" },

    { "from": "query", "to": "bm25" },
    { "from": "query", "to": "dense" },
    { "from": "query", "to": "visual" },
    { "from": "pgvector", "to": "dense", "variant": "dashed", "fromSide": "right", "toSide": "left" },
    { "from": "faiss", "to": "visual", "variant": "dashed", "fromSide": "right", "toSide": "left" },

    { "from": "bm25", "to": "fusion", "fromSide": "right", "toSide": "left" },
    { "from": "dense", "to": "fusion", "fromSide": "right", "toSide": "left" },
    { "from": "visual", "to": "fusion", "fromSide": "right", "toSide": "left" },
    { "from": "fusion", "to": "reranker" },
    { "from": "reranker", "to": "output" }
  ],
  "cards": [
    { "dot": "cyan", "title": "Three Retrieval Routes", "items": ["BM25 (blue): keyword/lexical matching on chunk text", "Dense (green): BGE query → pgvector HNSW cosine search", "Visual (purple): ColPali query → FAISS MaxSim → pgvector grounding"] },
    { "dot": "emerald", "title": "Fusion Pipeline", "items": ["RRF Fusion: reciprocal rank fusion of all 3 routes", "Cross-encoder rerank: BGE-reranker-large / zerank-2 (Top-20 → Top-5)", "HyDE: Qwen2:7b generates hypothetical document for query expansion"] },
    { "dot": "rose", "title": "Evaluation", "items": ["Ablation: 10 configs toggle BM25/Dense/Visual + reranker type", "ViDoRe benchmark: NDCG@5/10, Recall@5/10, MRR", "Config: models.yaml controls devices, paths, model IDs"] }
  ]
}